<section class="section">
  <div class="container">
    <div class="why-us-grid">
      <div class="why-us-visual">
        <div class="why-us-img">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: 'Neutron factory' }}
          {%- else -%}
            <div style="width:100%;height:480px;background:var(--surface-2);display:flex;align-items:center;justify-content:center;">
              <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.2">
                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
              </svg>
            </div>
          {%- endif -%}
        </div>
        <div class="why-us-badge">
          <div class="why-badge-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div class="why-badge-text">
            <strong>{{ section.settings.badge_number }}</strong>
            <span>{{ section.settings.badge_label }}</span>
          </div>
        </div>
      </div>

      <div class="why-us-content">
        <div class="section-label">{{ section.settings.label }}</div>
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
        <p class="section-sub" style="margin-bottom:0">{{ section.settings.subheading }}</p>

        <div class="why-list">
          {%- for block in section.blocks -%}
          <div class="why-item" {{ block.shopify_attributes }}>
            <div class="why-item-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div>
              <div class="why-item-title">{{ block.settings.title }}</div>
              <div class="why-item-text">{{ block.settings.text }}</div>
            </div>
          </div>
          {%- endfor -%}
        </div>

        <div style="margin-top:40px;">
          <a href="{{ section.settings.cta_url }}" class="btn btn-orange btn-lg">{{ section.settings.cta_text }}</a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Us",
  "settings": [
    {"type": "image_picker", "id": "image", "label": "Image"},
    {"type": "text", "id": "badge_number", "label": "Badge number", "default": "500+"},
    {"type": "text", "id": "badge_label", "label": "Badge label", "default": "Projects Completed"},
    {"type": "text", "id": "label", "label": "Section label", "default": "About Neutron"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Factory Direct, No Middleman"},
    {"type": "textarea", "id": "subheading", "label": "Subheading", "default": "We manufacture and supply complete photovoltaic systems — cutting out distributors to give you better pricing, shorter lead times, and direct technical access."},
    {"type": "text", "id": "cta_text", "label": "CTA text", "default": "Partner With Us"},
    {"type": "url", "id": "cta_url", "label": "CTA URL", "default": "/pages/contact"}
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Point",
      "settings": [
        {"type": "text", "id": "title", "label": "Title", "default": "Direct from the source"},
        {"type": "text", "id": "text", "label": "Description", "default": "Our manufacturing facilities in China produce panels and systems that we ship directly to your project site."}
      ]
    }
  ],
  "presets": [{
    "name": "Why Us",
    "blocks": [
      {"type": "item", "settings": {"title": "Factory Direct Pricing", "text": "No distributor markups. You buy directly from the source and pass the savings on to your clients."}},
      {"type": "item", "settings": {"title": "Flexible Order Sizes", "text": "Sample orders from 5kW. Container loads to multi-MW. We scale with your project requirements."}},
      {"type": "item", "settings": {"title": "Pre-Sales Engineering", "text": "Free system design review and energy yield estimation for your project site. Technical team available via WhatsApp."}},
      {"type": "item", "settings": {"title": "After-Sales Assurance", "text": "5-year product warranty. 25-year linear power output guarantee. Replacement dispatch within 72 hours."}}
    ]
  }]
}
{% endschema %}
