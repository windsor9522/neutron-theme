<section class="section">
  <div class="container">
    <div class="why-us-grid">
      <div class="why-us-visual">
        <div class="why-us-img">
          {%- if section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: 'Neutron factory' }}
          {%- else -%}
            <div style="width:100%;height:480px;background:var(--surface-2);display:flex;align-items:center;justify-content:center;border-radius:12px;">
              <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="var(--orange)" stroke-width="1">
                <rect x="2" y="3" width="20" height="18" rx="2"/>
                <path d="M8 3v18M2 9h6M2 15h6M16 8l-4 4 4 4"/>
              </svg>
            </div>
          {%- endif -%}
        </div>
        <div class="why-us-badge">
          <div class="why-badge-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div class="why-badge-text">
            <strong>{{ section.settings.badge_number }}</strong>
            <span>{{ section.settings.badge_label }}</span>
          </div>
        </div>
      </div>

      <div class="why-us-content">
        <div class="section-label">{{ section.settings.label }}</div>
        <h2 class="section-heading">{{ section.settings.heading }}</h2>
        <p class="section-sub" style="margin-bottom:0">{{ section.settings.subheading }}</p>

        <div class="why-list">
          {%- for block in section.blocks -%}
          <div class="why-item" {{ block.shopify_attributes }}>
            <div class="why-item-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div>
              <div class="why-item-title">{{ block.settings.title }}</div>
              <div class="why-item-text">{{ block.settings.text }}</div>
            </div>
          </div>
          {%- endfor -%}
        </div>

        <div style="margin-top:40px;">
          <a href="{{ section.settings.cta_url }}" class="btn btn-orange btn-lg">{{ section.settings.cta_text }}</a>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Us",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "badge_number",
      "label": "Badge number",
      "default": "ISO 9001"
    },
    {
      "type": "text",
      "id": "badge_label",
      "label": "Badge label",
      "default": "Certified Manufacturer"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Why Choose Neutron"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Complete Electrical Solutions, Factory Direct"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "NEUTRON LLC is a vertically integrated electrical equipment manufacturer based in Wenzhou, Zhejiang Province \u2014 the heart of China's electrical manufacturing industry. We design, produce, and export complete power solutions across 8 product categories."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Partner With Us"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Point",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Factory Direct Pricing"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Buy directly from the manufacturer. No distributor markups, no hidden costs."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Us",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "title": "Vertically Integrated Manufacturing",
            "text": "From raw materials to finished product \u2014 design, production, testing, and QC all under one roof in Wenzhou, China."
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Full Portfolio, One Supplier",
            "text": "PV equipment, switchgear, substations, EV charging, power quality \u2014 one partner for your entire electrical infrastructure."
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "International Standards",
            "text": "Products certified to IEC, GB, CE, and T\u00dcV standards. Customization for regional grid requirements available."
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Engineering Support Included",
            "text": "Free pre-sales technical consultation, system design review, and after-sales commissioning guidance."
          }
        }
      ]
    }
  ]
}
{% endschema %}
