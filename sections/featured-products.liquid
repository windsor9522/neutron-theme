<section class="section products-section">
  <div class="container">
    <div class="section-header">
      <div class="section-label">{{ section.settings.label }}</div>
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
      <p class="section-sub">{{ section.settings.subheading }}</p>
    </div>

    {%- if section.settings.collection != blank -%}
      {%- assign products = collections[section.settings.collection].products | limit: section.settings.products_count -%}
    {%- else -%}
      {%- assign products = collections.all.products | limit: section.settings.products_count -%}
    {%- endif -%}

    <div class="products-grid">
      {%- for product in products -%}
      <div class="product-card">
        <a href="{{ product.url }}" class="product-img">
          {%- if product.featured_image -%}
            {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title }}
          {%- else -%}
            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--surface-2);">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5">
                <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
              </svg>
            </div>
          {%- endif -%}
          {%- if product.tags contains 'new' -%}
            <span class="product-tag">New</span>
          {%- elsif product.tags contains 'bestseller' -%}
            <span class="product-tag" style="background:rgba(249,115,22,0.9)">Bestseller</span>
          {%- endif -%}
        </a>
        <div class="product-info">
          <h3 class="product-name">
            <a href="{{ product.url }}">{{ product.title }}</a>
          </h3>
          <p class="product-spec">{{ product.metafields.custom.spec | default: product.description | strip_html | truncate: 80 }}</p>
          <div class="product-price">
            {{ product.price_min | money }}
            <small>/ unit</small>
          </div>
          <div class="product-actions">
            <a href="{{ product.url }}" class="btn btn-ghost">View Details</a>
            <a href="/pages/contact?product={{ product.title | url_encode }}" class="btn btn-primary">Inquire</a>
          </div>
        </div>
      </div>
      {%- else -%}
        <p style="color:var(--muted);grid-column:1/-1;text-align:center;padding:40px 0;">No products found. Add products to your catalog to display them here.</p>
      {%- endfor -%}
    </div>

    <div style="text-align:center;margin-top:48px;">
      <a href="{{ section.settings.view_all_url | default: '/collections/all' }}" class="btn btn-ghost btn-lg">
        View All Products
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {"type": "text", "id": "label", "label": "Label", "default": "Our Products"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Solar Product Catalog"},
    {"type": "text", "id": "subheading", "label": "Subheading", "default": "High-efficiency modules, string inverters, hybrid systems, and mounting solutions — engineered for performance and longevity."},
    {"type": "collection", "id": "collection", "label": "Collection"},
    {"type": "range", "id": "products_count", "label": "Number of products", "min": 2, "max": 8, "step": 1, "default": 4},
    {"type": "url", "id": "view_all_url", "label": "View all URL", "default": "/collections/all"}
  ],
  "presets": [{"name": "Featured Products"}]
}
{% endschema %}
