<section class="section products-section">
  <div class="container">
    <div class="section-header" style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:24px;margin-bottom:48px;">
      <div>
        <div class="section-label">{{ section.settings.label }}</div>
        <h2 class="section-heading" style="margin-bottom:0">{{ section.settings.heading }}</h2>
      </div>
      <a href="{{ section.settings.view_all_url | default: '/collections/all' }}" class="btn btn-ghost">
        View Full Catalog
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    {%- if section.settings.collection != blank -%}
      {%- assign products = collections[section.settings.collection].products | limit: section.settings.products_count -%}
    {%- else -%}
      {%- assign products = collections.all.products | limit: section.settings.products_count -%}
    {%- endif -%}

    <div class="products-grid">
      {%- for product in products -%}
      <div class="product-card">
        <a href="{{ product.url }}" class="product-img">
          {%- if product.featured_image -%}
            {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title }}
          {%- else -%}
            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--surface-2);">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.2">
                <rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 3v18M2 9h6M2 15h6"/>
              </svg>
            </div>
          {%- endif -%}
          {%- if product.tags contains 'new' -%}
            <span class="product-tag">New</span>
          {%- elsif product.tags contains 'featured' -%}
            <span class="product-tag" style="background:rgba(249,115,22,0.9)">Featured</span>
          {%- endif -%}
        </a>
        <div class="product-info">
          <h3 class="product-name">
            <a href="{{ product.url }}">{{ product.title }}</a>
          </h3>
          <p class="product-spec">{{ product.description | strip_html | truncate: 90 }}</p>
          <div class="product-actions">
            <a href="{{ product.url }}" class="btn btn-ghost">Specifications</a>
            <a href="/pages/contact?product={{ product.title | url_encode }}" class="btn btn-primary">Get Quote</a>
          </div>
        </div>
      </div>
      {%- else -%}
      <!-- Placeholder cards when no products exist -->
      {%- assign placeholders = "XSLX-PV Junction Box,XSLX-AC Combiner Box,Photovoltaic Grid Cabinet,Box Transformer,European Substation,HV Switchgear" | split: "," -%}
      {%- for name in placeholders -%}
      <div class="product-card">
        <div class="product-img" style="cursor:default;">
          <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--surface-2);">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.2">
              <rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 3v18M2 9h6M2 15h6"/>
            </svg>
          </div>
        </div>
        <div class="product-info">
          <h3 class="product-name">{{ name }}</h3>
          <p class="product-spec">Industrial electrical equipment — IEC & CE certified. Contact us for full specifications and pricing.</p>
          <div class="product-actions">
            <a href="/pages/contact" class="btn btn-ghost">Specifications</a>
            <a href="/pages/contact" class="btn btn-primary">Get Quote</a>
          </div>
        </div>
      </div>
      {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    {"type": "text", "id": "label", "label": "Label", "default": "Core Products"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "Featured Equipment"},
    {"type": "collection", "id": "collection", "label": "Collection"},
    {"type": "range", "id": "products_count", "label": "Number of products", "min": 2, "max": 8, "step": 1, "default": 6},
    {"type": "url", "id": "view_all_url", "label": "View all URL", "default": "/collections/all"}
  ],
  "presets": [{"name": "Featured Products"}]
}
{% endschema %}
