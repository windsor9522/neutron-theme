<section class="section">
  <div class="container">
    <div class="section-header centered">
      <div class="section-label">{{ section.settings.label }}</div>
      <h2 class="section-heading">{{ section.settings.heading }}</h2>
      <p class="section-sub">{{ section.settings.subheading }}</p>
    </div>

    <div class="product-categories-grid">
      <a href="/collections/photovoltaic" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>
            <path d="M7 7h2v4H7zM11 7h2v4h-2zM15 7h2v4h-2z"/>
          </svg>
        </div>
        <div class="cat-info">
          <h3 class="cat-title">PV Equipment</h3>
          <p class="cat-sub">Junction Boxes · AC Combiner · Grid-Connected Cabinets · PV Box Transformers</p>
        </div>
        <div class="cat-arrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>

      <a href="/collections/substation" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <div class="cat-info">
          <h3 class="cat-title">Prefab Substations</h3>
          <p class="cat-sub">European Type · American Type · Box-Type Transformer Substations</p>
        </div>
        <div class="cat-arrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>

      <a href="/collections/hv-switchgear" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="2" y="3" width="20" height="18" rx="2"/><path d="M8 3v18M16 3v18M2 9h6M16 9h6M2 15h6M16 15h6"/>
          </svg>
        </div>
        <div class="cat-info">
          <h3 class="cat-title">HV Switchgear</h3>
          <p class="cat-sub">Armored Removable · Metal-Clad · Inflatable Ring Main Units</p>
        </div>
        <div class="cat-arrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>

      <a href="/collections/lv-switchgear" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="2" y="3" width="20" height="18" rx="2"/><path d="M2 9h20M8 9v12M16 9v12"/>
          </svg>
        </div>
        <div class="cat-info">
          <h3 class="cat-title">LV Switchgear</h3>
          <p class="cat-sub">Fixed Type · Draw-out Switch Cabinets · Power Distribution</p>
        </div>
        <div class="cat-arrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>

      <a href="/collections/power-quality" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
        </div>
        <div class="cat-info">
          <h3 class="cat-title">Power Quality</h3>
          <p class="cat-sub">Active Power Filter · Static Var Generator · Reactive Compensation</p>
        </div>
        <div class="cat-arrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>

      <a href="/collections/ev-charging" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/><rect x="9" y="11" width="14" height="10" rx="2"/>
            <path d="M13 16h5M16 13v6"/>
          </svg>
        </div>
        <div class="cat-info">
          <h3 class="cat-title">EV Charging</h3>
          <p class="cat-sub">Vertical AC Charging Pile · Vertical DC Charging Pile</p>
        </div>
        <div class="cat-arrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>

      <a href="/collections/distribution" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/>
            <line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/>
          </svg>
        </div>
        <div class="cat-info">
          <h3 class="cat-title">Distribution Equipment</h3>
          <p class="cat-sub">Cable Tap Boxes · Cable Distribution · Power Distribution Cabinets</p>
        </div>
        <div class="cat-arrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>

      <a href="/collections/control-systems" class="cat-card">
        <div class="cat-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </div>
        <div class="cat-info">
          <h3 class="cat-title">Control Systems</h3>
          <p class="cat-sub">DC Control Screen · HV Soft Start · Arc Suppression Cabinet</p>
        </div>
        <div class="cat-arrow">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Categories",
  "settings": [
    {"type": "text", "id": "label", "label": "Label", "default": "Product Range"},
    {"type": "text", "id": "heading", "label": "Heading", "default": "8 Complete Product Lines"},
    {"type": "text", "id": "subheading", "label": "Subheading", "default": "Every component your electrical infrastructure project requires — manufactured to IEC, CE, and GB standards, shipped worldwide."}
  ],
  "presets": [{"name": "Product Categories"}]
}
{% endschema %}
