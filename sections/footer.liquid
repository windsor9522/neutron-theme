<footer class="neutron-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="header-logo" style="font-size:18px;">
          <div class="logo-mark">
            <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 2L3 7v6l7 5 7-5V7L10 2z" fill="none" stroke="white" stroke-width="1.5"/>
              <path d="M10 5l4 3v4l-4 3-4-3V8l4-3z" fill="white"/>
            </svg>
          </div>
          {{ shop.name | upcase }}
        </a>
        <p class="footer-tagline">{{ section.settings.tagline }}</p>
        <div class="footer-social">
          {%- if section.settings.linkedin != blank -%}
          <a href="{{ section.settings.linkedin }}" class="social-link" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          {%- endif -%}
          {%- if section.settings.whatsapp != blank -%}
          <a href="https://wa.me/{{ section.settings.whatsapp }}" class="social-link" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.126.556 4.122 1.526 5.849L.057 23.983l6.268-1.643C7.926 23.412 9.918 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.959 0-3.8-.535-5.38-1.467l-.384-.229-3.98 1.044 1.06-3.88-.25-.402C2.006 15.8 1.5 13.963 1.5 12c0-5.799 4.701-10.5 10.5-10.5S22.5 6.201 22.5 12 17.799 22 12 22z"/>
            </svg>
          </a>
          {%- endif -%}
          {%- if section.settings.email != blank -%}
          <a href="mailto:{{ section.settings.email }}" class="social-link" aria-label="Email">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </a>
          {%- endif -%}
        </div>
      </div>

      <div>
        <div class="footer-col-title">Products</div>
        <div class="footer-links">
          <a href="/collections/photovoltaic">PV Equipment</a>
          <a href="/collections/substation">Prefab Substations</a>
          <a href="/collections/hv-switchgear">HV Switchgear</a>
          <a href="/collections/lv-switchgear">LV Switchgear</a>
          <a href="/collections/ev-charging">EV Charging</a>
          <a href="/collections/power-quality">Power Quality</a>
          <a href="/collections/distribution">Distribution Equipment</a>
          <a href="/collections/control-systems">Control Systems</a>
        </div>
      </div>

      <div>
        <div class="footer-col-title">Company</div>
        <div class="footer-links">
          <a href="/pages/about">About NEUTRON</a>
          <a href="/pages/certifications">Certifications</a>
          <a href="/pages/factory">Our Factory</a>
          <a href="/blogs/news">News</a>
          <a href="/pages/contact">Contact Us</a>
        </div>
      </div>

      <div>
        <div class="footer-col-title">Support</div>
        <div class="footer-links">
          <a href="/pages/contact">Request a Quote</a>
          <a href="/pages/shipping">Shipping & Delivery</a>
          <a href="/policies/refund-policy">Warranty Policy</a>
          <a href="/pages/faq">FAQ</a>
          <a href="/pages/contact">Technical Support</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-copyright">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved. · Wenzhou, Zhejiang, China</div>
      <div class="footer-certs">
        <span class="cert-badge">ISO 9001</span>
        <span class="cert-badge">IEC</span>
        <span class="cert-badge">CE</span>
        <span class="cert-badge">TÜV</span>
        <span class="cert-badge">CB</span>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {"type": "textarea", "id": "tagline", "label": "Tagline", "default": "Complete electrical power solutions — from photovoltaic systems to HV switchgear, substations, and EV charging infrastructure. Factory direct from Wenzhou, China."},
    {"type": "text", "id": "email", "label": "Email"},
    {"type": "text", "id": "whatsapp", "label": "WhatsApp number (digits only)"},
    {"type": "url", "id": "linkedin", "label": "LinkedIn URL"}
  ]
}
{% endschema %}
