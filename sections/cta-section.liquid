<section class="section cta-section">
  <div class="container">
    <div class="cta-inner">
      <div class="section-label" style="justify-content:center">{{ section.settings.label }}</div>
      <h2 class="cta-heading">{{ section.settings.heading_line1 }} <span>{{ section.settings.heading_line2 }}</span></h2>
      <p class="cta-sub">{{ section.settings.subheading }}</p>
      <div class="cta-actions">
        <a href="{{ section.settings.primary_url }}" class="btn btn-orange btn-lg">
          {{ section.settings.primary_text }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="{{ section.settings.secondary_url }}" class="btn btn-ghost btn-lg">{{ section.settings.secondary_text }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "CTA Section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Get Started"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading",
      "default": "Ready to Power Your"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading accent",
      "default": "Next Project?"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Send us your project specifications and receive a customized equipment quote within 24 hours. Our engineers are ready to assist."
    },
    {
      "type": "text",
      "id": "primary_text",
      "label": "Primary button",
      "default": "Request a Quote"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary URL"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary button",
      "default": "View Product Catalog"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary URL"
    }
  ],
  "presets": [
    {
      "name": "CTA Section"
    }
  ]
}
{% endschema %}
