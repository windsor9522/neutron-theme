{% if page.handle == 'contact' %}

<style>
.contact-wrap { max-width: 1100px; margin: 0 auto; padding: 80px 24px; }
.contact-top { text-align: center; margin-bottom: 64px; }
.contact-top .section-label { justify-content: center; }
.contact-top h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; color: var(--text); margin: 12px 0; }
.contact-top p { color: var(--muted); font-size: 1.05rem; max-width: 600px; margin: 0 auto; }
.contact-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-bottom: 48px; }
@media (max-width: 768px) { .contact-cards { grid-template-columns: 1fr; } }
.contact-card {
  background: var(--surface-1);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 32px 28px;
  transition: border-color 0.2s;
}
.contact-card:hover { border-color: var(--orange); }
.contact-card-icon {
  width: 48px; height: 48px;
  background: rgba(255,107,0,0.12);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 20px;
  color: var(--orange);
}
.contact-card h3 { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 12px; }
.contact-card .contact-value { font-size: 1rem; color: var(--text); font-weight: 600; line-height: 1.5; }
.contact-card .contact-value a { color: var(--orange); text-decoration: none; }
.contact-card .contact-value a:hover { text-decoration: underline; }
.contact-card .contact-sub { font-size: 0.82rem; color: var(--muted); margin-top: 6px; }
.contact-bottom { background: var(--surface-1); border: 1px solid var(--border); border-radius: 16px; padding: 40px 48px; display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
.contact-bottom h2 { font-size: 1.4rem; font-weight: 700; color: var(--text); margin-bottom: 8px; }
.contact-bottom p { color: var(--muted); font-size: 0.9rem; max-width: 480px; }
.contact-bottom-actions { display: flex; gap: 12px; flex-wrap: wrap; }
.contact-address { background: var(--surface-2); border-radius: 10px; padding: 20px 24px; margin-top: 24px; display: flex; gap: 14px; align-items: flex-start; }
.contact-address svg { color: var(--orange); flex-shrink: 0; margin-top: 2px; }
.contact-address-text { font-size: 0.88rem; color: var(--muted); line-height: 1.6; }
.contact-address-text strong { color: var(--text); display: block; margin-bottom: 4px; }
</style>

<main class="contact-wrap">
  <div class="contact-top">
    <div class="section-label">NEUTRON LLC</div>
    <h1>Contact Us</h1>
    <p>Our sales team is ready to assist with product inquiries, technical specifications, project quotes, and after-sales support.</p>
  </div>

  <div class="contact-cards">
    <div class="contact-card">
      <div class="contact-card-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
