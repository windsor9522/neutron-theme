      </div>
      <h3>Email</h3>
      <div class="contact-value"><a href="mailto:neutronllc@outlook.com">neutronllc@outlook.com</a></div>
      <div class="contact-sub">Quotes &amp; Technical Inquiries</div>
    </div>

    <div class="contact-card">
      <div class="contact-card-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
      </div>
      <h3>Business Hours</h3>
      <div class="contact-value">Mon – Sun</div>
      <div class="contact-value">09:00 – 18:00 CST</div>
