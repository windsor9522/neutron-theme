<section class="collection-header">
  <div class="container">
    <div class="section-label">Catalog</div>
    <h1 class="section-heading">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <p class="section-sub">{{ collection.description }}</p>
    {%- endif -%}
  </div>
</section>

<div class="container">
  <div class="collection-grid">
    {%- for product in collection.products -%}
    <div class="product-card">
      <a href="{{ product.url }}" class="product-img">
        {%- if product.featured_image -%}
          {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: product.title }}
        {%- endif -%}
      </a>
      <div class="product-info">
        <h2 class="product-name"><a href="{{ product.url }}">{{ product.title }}</a></h2>
        <p class="product-spec">{{ product.description | strip_html | truncate: 80 }}</p>
        <div class="product-price">{{ product.price_min | money }} <small>/ unit</small></div>
        <div class="product-actions">
          <a href="{{ product.url }}" class="btn btn-ghost">View Details</a>
          <a href="/pages/contact?product={{ product.title | url_encode }}" class="btn btn-primary">Inquire</a>
        </div>
      </div>
    </div>
    {%- else -%}
    <p style="color:var(--muted);grid-column:1/-1;text-align:center;padding:80px 0;">No products in this collection yet.</p>
    {%- endfor -%}
  </div>
</div>
